# ===========================================
# AI销售助手 - 环境变量配置模板
# ===========================================
# 复制此文件为 .env 并填写实际配置值

# ===========================================
# 数据库配置 (必需)
# ===========================================
# SQLite (开发环境)
# DATABASE_URL=sqlite+aiosqlite:///./sales_assistant.db

# PostgreSQL (生产环境)
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/sales_assistant

# SQLite迁移时的源数据库URL (可选，仅迁移时使用)
# SQLITE_DATABASE_URL=sqlite+aiosqlite:///./sales_assistant.db

# 数据库连接池配置 (PostgreSQL)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_PRE_PING=true

# ===========================================
# 安全配置 (必需)
# ===========================================
# JWT密钥 - 生产环境必须设置强密钥！
# 生成方法: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-in-production

# JWT算法和过期时间
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===========================================
# CORS配置
# ===========================================
# 允许的前端域名，多个用逗号分隔
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ===========================================
# AI服务配置 (可选)
# ===========================================
# 通义千问API密钥
DASHSCOPE_API_KEY=your-dashscope-api-key

# AI模型选择
DASHSCOPE_MODEL=qwen-max

# ===========================================
# 应用配置
# ===========================================
APP_NAME=AI销售助手
APP_VERSION=1.0.0
DEBUG=false

# ===========================================
# Redis配置 (可选，用于缓存)
# ===========================================
# REDIS_URL=redis://localhost:6379/0
